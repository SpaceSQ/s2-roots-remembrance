{
  "pluginId": "s2-space-agent-os",
  "version": "1.1.3",
  "type": "native-code",
  "entry": "handler.py",
  "runtime": "python3",
  "capabilities": {
    "spatial_logic": true,
    "heartbeat_sync": true,
    "secure_actuation": true
  },
  "permissions": {
    "files": ["s2_local_context_logs/", "s2_data_cache/"],
    "network": ["localhost:11434", "api.tuya.com", "home-assistant.local"],
    "tools": ["exec", "file_read", "file_write", "http_request"]
  },
  "mcp_config": {
    "auto_discovery": true,
    "protocol_version": "2026.3.22"
  }
}