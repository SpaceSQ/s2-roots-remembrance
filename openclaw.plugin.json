{
  "id": "s2-space-agent-os",
  "pluginId": "s2-space-agent-os",
  "version": "1.1.3",
  "type": "native-code",
  "entry": "handler.py",
  "runtime": "python3",
  "config_schema": {
    "type": "object",
    "required": ["S2_PRIVACY_CONSENT"],
    "properties": {
      "S2_PRIVACY_CONSENT": {
        "type": "string",
        "description": "Set to '1' to consent to spatial data processing.",
        "default": "0"
      },
      "S2_ENABLE_REAL_ACTUATION": {
        "type": "string",
        "description": "Set to '1' to enable physical IoT device control.",
        "default": "0"
      },
      "HA_URL": {
        "type": "string",
        "description": "Your Home Assistant Instance URL (e.g., http://192.168.1.100:8123)."
      },
      "HA_TOKEN": {
        "type": "string",
        "description": "Long-lived Access Token for Home Assistant API."
      }
    }
  },
  "capabilities": {
    "spatial_logic": true,
    "heartbeat_sync": true,
    "secure_actuation": true
  },
  "permissions": {
    "files": [
      "s2_local_context_logs/", 
      "s2_data_cache/"
    ],
    "network": [
      "localhost:11434", 
      "api.tuya.com", 
      "home-assistant.local"
    ],
    "tools": [
      "exec", 
      "file_read", 
      "file_write", 
      "http_request"
    ]
  },
  "mcp_config": {
    "auto_discovery": true,
    "protocol_version": "2026.3.22"
  }
}